public class BinaryFunction {


    public static int[] getBinaryArray(int number) {

        if (number == 0) {
            return new int[]{0};
        }

        int temp = number;
        int count = 0;

        while (temp > 0) {
            temp = temp / 2;
            count++;
        }

        int[] binary = new int[count];

        int index = count - 1;

        while (number > 0) {
            binary[index] = number % 2;
            number = number / 2;
            index--;
        }

        return binary;
    }

    public static void main(String[] args) {

        int num = 27;

        int[] result = getBinaryArray(num);

        System.out.print("Binary digits: ");
        for (int bit : result) {
            System.out.print(bit);
        }
    }
}
