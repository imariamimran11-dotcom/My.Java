public class binaryStringFunction {

     public static String getBinaryString(int number) {

        if (number == 0) {
            return "0";
        }

        String binary = "";

        while (number > 0) {
            binary = (number % 2) + binary;
            number = number / 2;
        }

        return binary;
    }


    public static void main(String[] args) {

        int num = 26;

        String result = getBinaryString(num);

        System.out.println("Binary representation: " + result);
    }
}
